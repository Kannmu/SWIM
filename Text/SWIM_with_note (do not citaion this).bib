@article{andrewsUniversalScalingLaw2020,
  title = {A Universal Scaling Law of Mammalian Touch},
  author = {Andrews, J. W. and Adams, M. J. and Montenegro-Johnson, T. D.},
  date = {2020-10-09},
  journaltitle = {Science Advances},
  shortjournal = {Sci. Adv.},
  doi = {10.1126/sciadv.abb6912},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: Andrews et al. present a comprehensive mathematical study investigating the physical mechanisms underlying mammalian vibrotaction, specifically addressing how diverse species perceive vibrations despite significant variations in skin properties such as stiffness and thickness. The authors argue that while touch is a primordial sense reliant on mechanoreceptors converting mechanical vibrations into electrical signals, the properties of mammalian skin vary wildly between species, ranging from the stiff hide of an elephant to human skin which varies with age, gender, and location, raising the question of how perceptual constancy is maintained. Focusing on Pacinian corpuscles (PCs), which detect vibrations between 20 and 1000 Hz and are located deep within the skin near the dermis-hypodermis boundary as shown in the schematic model in Figure 1, the study challenges previous assumptions that relied primarily on P-waves (compression) and S-waves (shear). Instead, through the development of a mathematical model treating skin as a layered viscoelastic solid coupled with a model of the PC mechanoreceptors, the authors demonstrate that vibrotaction is dominated by long-wavelength Rayleigh waves that travel cooperatively through all layers of the skin and bone, rather than solely along the surface or through the bulk material. The mathematical framework draws upon the physics of earthquake wave propagation, utilizing asymptotic expansions of the governing equations for elastic layers as originally proposed by Bromwich and extended by Lamb, noting that while viscoelasticity contributes to wave damping, the waves are fundamentally elastic for the distances relevant to human touch (approximately 1 to 2 meters). The analysis systematically rules out Love waves as a viable mechanism for exciting mechanoreceptors because the necessary conditions regarding S-wave velocity ratios and minimum layer thicknesses (0.8{$\lambda$}) are not satisfied in any mammalian skin layers considered. Furthermore, the dispersion relation derived for Rayleigh waves indicates that these waves exhibit significantly slower amplitude decay compared to P- and S-waves as they propagate away from the excitation source, as illustrated in Figure 2, allowing for long-range and temporal discrimination of tactile signals. Crucially, the study incorporates a detailed model of the Pacinian corpuscle structure, characterized by an onion-like arrangement of lamellae with viscous fluid, which acts as a filter that significantly reduces the transmission of P-wave energy, particularly the zeroth mode of deformation, thereby rendering Rayleigh waves approximately 100 to 10,000 times more effective at stimulating the nerve core depending on frequency, as demonstrated in Figures 3B and 3D. The authors further establish that these cooperative Rayleigh waves penetrate deeply with less than 2.5\% amplitude decay at the bone surface for typical detection frequencies, confirming that the waves travel through all material layers simultaneously due to matched displacements and stress conditions. This dominance of Rayleigh waves provides a physical basis for perceptual constancy, as the study demonstrates via numerical simulation that Rayleigh wave properties remain largely insensitive to variations in the stiffness of the outermost stratum corneum, unlike P- and S-waves, meaning that changes in skin hydration or composition do not disrupt tactile sensitivity, a finding supported by the data presented in Figure 4. Extending the model to a comparative analysis across multiple mammalian species, the researchers identify a universal scaling law where the ratio of the skin Rayleigh wavelength to the depth of the Pacinian corpuscles (DPC) is evolutionarily conserved at approximately 5/2 for large mammals, excluding rodents which deviate likely due to differences in PC location relative to tendons, limb geometry, or cartilage proportions, as plotted in Figure 5. This conserved constant ensures that Rayleigh waves remain the primary stimulus for mechanoreceptors across species, avoiding interference from Love waves and maintaining insensitivity to hydration levels, although the model is noted to apply specifically to bone-supported regions like limbs and the head rather than unsupported areas like the thorax. Finally, the methodology involved mathematical analysis of the Cauchy momentum equations for layered materials with viscous decay, evaluated using MATLAB with parameters sourced from existing literature, validating the theoretical predictions against experimental data to confirm that the interaction of Rayleigh waves with PCs is an evolutionarily conserved feature essential for the sensation of vibrations in mammals.}
}

@article{bodoSensingMotionTact2010,
  title = {Sensing Motion with Tact},
  author = {Bodo, Cristian},
  date = {2010-03},
  journaltitle = {Nature Reviews Neuroscience},
  shortjournal = {Nat. Rev. Neurosci.},
  doi = {10.1038/nrn2816},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: When we handle an object, the relative movement between its surface and our skin provides the brain with valuable information about its characteristics, and while the existence of a subpopulation of neurons in the visual cortex that responds specifically to the direction of movement of a visual stimulus is widely known, it remains unclear whether the perception of tactile motion relies on an analogous mechanism, prompting Pei et al. to identify a population of neurons in the somatosensory cortex that encode the direction of a moving tactile stimulus regardless of its shape, its speed or the force with which it contacts the skin, implying a strong analogy between visual and tactile motion processing. The authors stimulated the fingertips of rhesus macaques in precise spatiotemporal sequences to create the tactile equivalent of pixels on a monitor, and when the tactile stimulus was applied, different subpopulations of neurons in area 1 of the somatosensory cortex responded preferentially to specific directions of motion, with the preferred direction of a given subpopulation remaining the same for different types of moving stimuli including a solid bar, a regular pattern of dots, or displays of dots the motion of which varied in overall coherence. Moreover, by examining responses from individual neurons in the macaques, the authors could discriminate between directions of movement of the stimulus with similar accuracy to human subjects receiving the same type of tactile stimulation, suggesting that the response of these neurons might underlie the ability to perceive the direction of tactile motion, although this remains to be shown in experiments in which the same individual provides both behavioural and electrophysiological data. In vision, information about motion is encoded by specialized neuronal subpopulations at each stage of processing and, ascending the perceptual pathway, motion representations become increasingly independent of other object properties, and the findings in this study suggest that this may be the general case in the development of motion representations, regardless of whether we experience the moving stimulus through our eyes or our fingertips.}
}

@article{bolanowskiFourChannelsMediate1988,
  title = {Four Channels Mediate the Mechanical Aspects of Touch},
  author = {Bolanowski, S. J. and Gescheider, G. A. and Verrillo, R. T. and Checkosky, C. M.},
  date = {1988-11-01},
  journaltitle = {Journal of the Acoustical Society of America},
  shortjournal = {J. Acoust. Soc. Am.},
  doi = {10.1121/1.397184},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: Bolanowski et al. present evidence that four distinct channels mediate the mechanical aspects of touch in human glabrous skin, challenging the previous assumption that only three psychophysical channels correspond to the four identified afferent fiber types comprising Pacinian corpuscles, rapidly adapting fibers, type I slowly adapting fibers, and type II slowly adapting fibers. While prior physiological experiments isolated these four fiber groups, psychophysical assays typically assayed only three, leading to uncertainty regarding the contribution of SA II fibers to tactile perception; however, this study utilizes selective masking, skin-surface temperature modification, and testing down to very low vibratory frequencies to define a fourth psychophysical channel designated NP III. The research concludes that these four channels operate in conjunction across a vibratory range extending from at least 0.4 Hz to greater than 500 Hz, with each channel mediating a specific portion of the overall threshold frequency characteristic, specifically mapping the P channel to PC fibers, NP I to RA fibers, NP II to SA II fibers, and NP III to SA I fibers. The introduction reviews existing literature indicating that Pacinian corpuscle afferents mediate the P channel which operates between 40 and 800 Hz with maximum sensitivity near 300 Hz and exhibits spatial and temporal summation, whereas the non-Pacinian I channel mediates flutter sensations between 10 and 100 Hz without summation or temperature sensitivity, and the non-Pacinian II channel operates similarly to the P channel at lower sensitivity and is temperature sensitive. Prior to this study, evidence suggested only three channels contributed to vibrotactile sensation, supported by findings that electrical activation of SA II fibers did not elicit conscious perception, yet the authors argue that psychophysical measurements are necessary to reassess whether a fourth low-threshold mechanoreceptive channel contributes to touch, hypothesizing it would likely operate at very low frequencies given the sensation of pressure associated with SA I fibers. The methods section details the use of a Goodman 90A vibrator under computer control applied to the thenar eminence with static indentation, utilizing circular contact surface areas of 0.008 and 2.9 cm2 surrounded by a rigid surface to confine deformations, with skin-surface temperature controlled at 15, 30, and 40 degrees Celsius via circulating water chambers. Stimuli consisted of sinusoidal bursts with durations of 700 or 2400 ms, and forward masking paradigms were employed where a conditioning stimulus preceded the test stimulus to differentiate independent channels based on the principle that masking occurs only when masker and test stimuli excite the same channel. Thresholds were measured using a two-alternative forced-choice tracking procedure requiring 75\% correct detection over three minutes, with five experienced subjects participating in the experiments conducted primarily at 30 degrees Celsius. Results indicate that the vibrotactile frequency response consists of a low-frequency portion between 0.4 and 3.0 Hz appearing frequency insensitive, a middle-frequency portion with a slope of approximately -5.0 dB/octave, and a U-shaped high-frequency portion produced by the P channel, suggesting the presence of separate channels for the low and middle frequency regions rather than a single system. Masking experiments revealed that a 40-Hz masking stimulus did not affect the threshold of a 0.7-Hz test stimulus until masker levels exceeded 14 dB SL, defining a breakpoint that indicated the channel mediating the 0.7-Hz stimulus was distinct from the P or NP II channels, thereby substantiating the existence of a separate low-frequency channel termed NP III. Further analysis of temperature effects showed that skin-surface temperature significantly affected thresholds mediated by both NP I and NP III channels, particularly in the region between 1.5 and 4 Hz where their sensitivities merge, contradicting previous reports that NP I was temperature insensitive due to investigations limited to frequencies above 12 Hz. Investigations into stimulus size and duration demonstrated that the NP III channel does not exhibit spatial summation, as thresholds obtained with a smaller contactor area were not statistically different from those with a larger area, nor does it display temporal summation since increasing stimulus duration from 700 to 2500 ms yielded no significant difference in sensitivity, while spectral analysis confirmed harmonic components were significantly smaller than the fundamental frequency ensuring detection was not confounded by subharmonic energy. The discussion synthesizes these findings into a four-channel model where the previously unknown fourth channel NP III operates from 0.4 to 100 Hz with sensitivity comparable to NP I and is affected by skin temperature but lacks spatial summation capabilities. By correlating psychophysically defined channels with neurophysiological data from Johansson et al., the authors propose specific neural codes for each channel, suggesting NP I relies on a single impulse per stimulus burst, the P channel requires between two and four impulses per stimulus to account for temporal summation, NP III may utilize an impulse rate of approximately 0.8 impulses per second, and NP II likely requires several SA II fibers activated simultaneously or a substantial increase in firing rate above spontaneous activity given its temporal summation properties. The complete model indicates that while a single channel may signal the threshold event depending on stimulation frequency, at certain frequencies such as 2.0 to 4.0 Hz and 35 Hz, more than one channel may be stimulated even at threshold-level intensities, implying probability summation between channels. Furthermore, the model suggests that suprathreshold stimuli may activate multiple channels simultaneously, meaning perceptual qualities like itch, tickle, or texture might result from combined inputs rather than activity in a single channel encoding intensity alone. Consequently, understanding sensory experiences such as roughness or softness may require establishing criterion responses across all receptor types and developing multichannel stimulation techniques for prosthetic devices, highlighting that the code for perceptual quality is more sophisticated than previously realized, involving contributions from all four channels to form fundamental attributes like pressure, flutter, and vibration.}
}

@article{bradleyRankAnalysisIncomplete1952,
  title = {Rank Analysis of Incomplete Block Designs: {{The}} Method of Paired Comparisons},
  shorttitle = {Rank Analysis of Incomplete Block Designs},
  author = {Bradley, Ralph Allan and Terry, Milton E.},
  date = {1952},
  journaltitle = {Biometrika},
  shortjournal = {Biometrika},
  doi = {10.1093/biomet/39.3-4.324},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This research paper by Ralph Allan Bradley and Milton E. Terry presents a comprehensive statistical methodology for the rank analysis of incomplete block designs specifically tailored to the method of paired comparisons, building upon and generalizing previous works by Thurstone, Mosteller, Kendall, Babington Smith, and Guttman. The introduction establishes the necessity for a model that does not rely on assumptions of linear variates or normality, proposing instead a mathematical model where maximum-likelihood estimates of treatment ratings provide a simple solution to quantification problems while likelihood ratio statistics enable rigorous hypothesis testing. The mathematical model defines \$t\$ treatments with true ratings \$\textbackslash pi\_i\$ subject to the constraints \$\textbackslash pi\_i \textbackslash ge 0\$ and \$\textbackslash sum \textbackslash pi\_i = 1\$, positing that the probability of treatment \$i\$ receiving a top ranking against treatment \$j\$ is \$\textbackslash pi\_i / (\textbackslash pi\_i + \textbackslash pi\_j)\$, and allows for the extension of these parameters to vary across different judges or time periods denoted by a subscript \$u\$. The likelihood function is derived under the assumption of probability independence between blocks, resulting in a general form that serves as the foundation for subsequent inference, which is adapted for scenarios where distinct parameters exist for different groups of repetitions. A general class of likelihood ratio tests is formulated to evaluate the null hypothesis that all treatment ratings are equal against alternative hypotheses where treatments share identical ratings within \$m\$ specified groups, with maximum-likelihood estimates obtained by solving equations derived from the logarithm of the likelihood function using Lagrange multipliers for parameter restraints. The test statistic is constructed as a monotone function of the likelihood ratio that depends implicitly on treatment sums of ranks, facilitating pairwise comparisons where the ratio of estimated probabilities measures the relative frequency of occurrence of rank one for any pair of items. Two special cases of these tests are highlighted: the first examines the hypothesis that no treatment rating is equal to any other, simplifying the estimation equations and defining a statistic \$B\_1\$ whose exact distribution is tabulated, while the second considers a reduction to two groups of treatments similar to single degree of freedom comparisons in analysis of variance, yielding an explicit statistic \$B\_2\$ calculated directly from treatment sums of ranks. To support practical application, the authors describe a systematic procedure for generating tables of treatment sums of ranks and their associated probabilities under the null hypothesis, utilizing iterative computational methods implemented on IBM equipment to solve the estimation equations for cases where elementary methods are insufficient, with Appendix A providing cumulative probabilities and significance levels for \$B\_1\$ for up to ten repetitions and three or four treatments. The paper further addresses the aggregation of experimental data, distinguishing between pooled analysis which assumes uniform ratings across groups and combined analysis which permits ratings to vary by group while testing overall significance using the additive statistic \$B'\_1 = \textbackslash sum B\_1\textasciicircum\{(u)\}\$, noting that the decision to pool or combine relies on a priori knowledge of judge behavior to avoid masking significant subgroup differences. A coefficient of agreement is introduced to quantify consistency of ranking between groups based on the difference between pooled and combined statistics, with both conditional exact tests for small samples and large sample asymptotic distributions discussed, where the latter utilizes Wilks theorem to establish that the likelihood ratio statistics converge to Chi-square distributions with degrees of freedom dependent on the number of treatments and groups. Although numerical computations indicate that the mean and variance of the test statistics converge rapidly to limiting values for small numbers of items, the approximation is noted to be fairly reliable only when the number of repetitions exceeds fifteen, and an illustrative taste-testing experiment involving pork roasts from three different corn rations demonstrates the step-by-step application of the method, revealing that while individual judges showed some significance, the combined analysis yielded a significance level of 0.069 and indicated poor agreement between judges when pooling was attempted. The discussion concludes by emphasizing the simplicity and appeal of the experimental design and analysis, which require only the addition of small integers and consultation of prepared tables, and notes that while power calculations were not undertaken due to complexity, the probabilities tabulated in the appendices may prove useful for other applications of ranking methods in incomplete blocks of size two, ultimately summarizing a flexible and robust framework for detecting treatment differences in subjective ranking problems involving qualitative measurements and small panels of judges.}
}

@article{castellanbaldanHistidineDecarboxylaseDeficiency2014,
  title = {Histidine Decarboxylase Deficiency Causes Tourette Syndrome: {{Parallel}} Findings in Humans and Mice},
  shorttitle = {Histidine {{Decarboxylase Deficiency Causes Tourette Syndrome}}},
  author = {Castellan Baldan, Lissandra and Williams, Kyle~A. and Gallezot, Jean-Dominique and Pogorelov, Vladimir and Rapanelli, Maximiliano and Crowley, Michael and Anderson, George~M. and Loring, Erin and Gorczyca, Roxanne and Billingslea, Eileen and Wasylink, Suzanne and Panza, Kaitlyn~E. and Ercan-Sencicek, A.~Gulhan and Krusong, Kuakarun and Leventhal, Bennett~L. and Ohtsu, Hiroshi and Bloch, Michael~H. and Hughes, Zo\"e~A. and Krystal, John~H. and Mayes, Linda and {de~Araujo}, Ivan and Ding, Yu-Shin and State, Matthew~W. and Pittenger, Christopher},
  date = {2014-01},
  journaltitle = {Neuron},
  shortjournal = {Neuron},
  doi = {10.1016/j.neuron.2013.10.052},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This study establishes Histidine decarboxylase (Hdc) deficiency as a rare genetic cause of Tourette syndrome by demonstrating parallel phenotypic and neurochemical findings in humans carrying the Hdc W317X mutation and in Hdc knockout mice. The abstract outlines that Hdc knockout mice exhibit potentiated tic-like stereotypies recapitulating core Tourette phenomenology, which were mitigated by the dopamine D2 antagonist haloperidol and by histamine infusion into the brain. Furthermore, prepulse inhibition was impaired in both mice and humans with Hdc mutations, while histamine infusion reduced striatal dopamine levels, contrasting with the increased striatal dopamine and upregulated Fos expression found in Hdc knockout mice. Dopamine D2/D3 receptor binding was also altered in both species, confirming HDC deficiency as a cause of Tourette syndrome and identifying histamine-dopamine interactions in the basal ganglia as a critical locus of pathology. The introduction reviews Tourette syndrome characteristics including motor and vocal tics and sensorimotor gating deficiencies associated with cortico-basal ganglia circuit dysregulation, noting that while common polymorphisms remain elusive, a rare segregating nonsense mutation in the Hdc gene provides a high-penetrance allele to test hypotheses regarding histaminergic modulation of dopaminergic circuits. Results indicate that individuals carrying the hypomorphic Hdc allele exhibit tics within a typical severity range, while Hdc knockout and heterozygous mice display normal baseline locomotion but show markedly increased motor stereotypies following D-amphetamine administration, a phenotype that persists across ages and is sensitive to haloperidol pretreatment. Specifically, stereotypies in Hdc knockout mice were significantly mitigated by haloperidol, and direct intracerebroventricular infusion of histamine almost completely eliminated focused sniffing stereotypies in both genotypes without simply causing sedation, supporting the hypothesis that reduced histamine production drives tic-like behavior. Sensorimotor gating deficits measured by prepulse inhibition of startle were observed in patients carrying the Hdc W317X mutation and were successfully recapitulated in Hdc knockout and heterozygous mice, providing valuable reinforcing face validity for the animal model. Neurochemical analysis revealed that histamine negatively regulates striatal dopamine, as evidenced by reduced dopamine levels following histamine infusion in wild-type mice and increased striatal dopamine during the active dark phase in Hdc knockout mice. Examination of neuronal activation via Fos immunoreactivity showed that baseline Fos was modestly elevated in Hdc knockout mice and markedly potentiated in striasomal compartments following amphetamine injection, suggesting chronic dopaminergic hyperstimulation and an imbalance between striasomal and matrix pathways. Receptor studies using positron emission tomography in humans and ex vivo binding in mice demonstrated dysregulated D2/D3 receptors, with increased binding in the substantia nigra and globus pallidus in patients and elevated substantia nigra binding alongside reduced dorsal striatal binding in mice, consistent with compensatory responses to chronic dopaminergic elevation. The discussion interprets these findings to confirm the causal association between Hdc disruption and Tourette syndrome, highlighting histamine regulation of dopaminergic modulation in the basal ganglia as a central mechanism that may explain circadian variations in symptomatology given histamine's role in arousal. The authors argue that Hdc knockout mice represent a pathophysiologically realistic model with construct validity derived from a disease-associated allele, exhibiting reinforcing face and predictive validity through behavioral phenotypes and pharmacological responsiveness. Finally, the methods section details the generation of Hdc knockout mice, enzymatic assays for histidine decarboxylase activity, behavioral testing protocols including open field exploration and amphetamine challenges, startle and prepulse inhibition measurements, in vivo microdialysis for dopamine and histamine quantification, Fos immunohistochemistry, and positron emission tomography imaging using the radiotracer [11C]-PHNO in human subjects to validate the translational relevance of the murine findings.}
}

@article{chunArtificialNeuralTactile2021,
  title = {An Artificial Neural Tactile Sensing System},
  author = {Chun, Sungwoo and Kim, Jong-Seok and Yoo, Yongsang and Choi, Youngin and Jung, Sung Jun and Jang, Dongpyo and Lee, Gwangyeob and Song, Kang-Il and Nam, Kum Seok and Youn, Inchan and Son, Donghee and Pang, Changhyun and Jeong, Yong and Jung, Hachul and Kim, Young-Jin and Choi, Byong-Deok and Kim, Jaehun and Kim, Sung-Phil and Park, Wanjun and Park, Seongjun},
  date = {2021-06-03},
  journaltitle = {Nature Electronics},
  shortjournal = {Nat. Electron.},
  doi = {10.1038/s41928-021-00585-x},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This research article addresses the complexity of human tactile perception which relies on the detection of pressure and vibration through spatiotemporal mechanical deformations on glabrous skin mediated by slow adaptive and fast adaptive cutaneous mechanoreceptors. While various strategies exist for mimicking these receptor types using capacitive, piezoresistive, optical, piezoelectric, or triboelectric methods, few demonstrations achieve both functions simultaneously with human-compatible properties such as being thin, lightweight, adhesive, and economically mass-producible. Consequently, this study reports the development of a human-like artificial neural tactile skin system consisting of sensors that simultaneously mimic slow adaptive and fast adaptive mechanoreceptors alongside a neural stimulator that generates sensory neuron-like signals similar to real tactile nerve signals. The system enables selective and sensitive detection of pressure and vibration and facilitates the delivery of realistic tactile signals to a nervous system by mimicking the biological neural tactile system. In biological sensory systems, tactile stimuli are converted to action potentials through somatosensory transduction and transmitted via afferent nerves where slow adaptive mechanoreceptors generate voltage spikes dependent on sustained stimulus strength while fast adaptive mechanoreceptors generate spikes at initial contact and release. The artificial tactile sensory system emulates these mechanoreceptor functions and the patterns of transmitted neural signals to achieve multilevel information on tactile perception. The core of the device involves stretchable artificial skin fabricated using conductive piezoresistive and piezoelectric particles within an elastic polymer matrix, specifically cubic or tetragonal barium titanate nanoparticles surrounded by high-aspect-ratio plate-type reduced graphene oxide sheets uniformly distributed in a polydimethylsiloxane polymer matrix. The barium titanate nanoparticles generate piezoelectric potential under physical stimuli to sensitively detect vibration mimicking fast adaptive mechanoreceptors while the reduced graphene oxide sheets mimic slow adaptive mechanoreceptors by showing sensitive piezoresistive responses to static pressure. The reduced graphene oxide sheets form electrical connections enabling uniform dispersion of barium titanate nanoparticles and reducing current loss from decreasing internal resistance. To optimize performance, the electrical conductivity of the films was measured to determine the optimal filler fractions where the slow adaptive sensor utilizes rgo content slightly above the electrical percolation threshold for high pressure sensitivity whereas the fast adaptive sensor utilizes rgo content that does not provide electrical connection to preserve piezoelectric potential. The fabricated films are characterized as ultrathin lighter than one hundred twenty micrometers lightweight weighing fifteen milligrams per square centimeter freely transformable with perfect reversibility and adhesive with a peel energy greater than ten joules per square meter without chemical adhesives providing high resemblance to biological skin. The sensors can be employed in a passive body skin system where two thin T-skin films with different rgo contents are sandwiched by carbon black-polydimethylsiloxane electrodes and superimposed over a dielectric polydimethylsiloxane insulator to isolate electrical crosstalk. The slow adaptive sensor presents responses sensitive to the magnitude of static pressure due to piezoresistive effects induced by variation in percolation resistance enhanced by barium titanate nanoparticles forming spatial vacancies inside the film while the barium titanate-enriched piezoelectric fast adaptive sensor responds sensitively to vibrations due to fluctuating dipole magnitudes. The electrical responses were derived with pressure and vibration stimulation corresponding to everyday physical stimuli detected by humans demonstrating that the sensors mimic the properties and functions of skin mechanoreceptors even in ten thousand repeated measurements. Notably the fast adaptive sensor can detect high-frequency vibrations up to one thousand hertz exceeding the human vibration detection range of five hundred hertz while the slow adaptive sensor does not respond to high-frequency vibrations indicating selective vibration detection capabilities. A critical component of the system is the signal-converting mechanism which modulates the sensor outputs into neuron-mimicking signals separately based on recorded response patterns of mouse nerves ex vivo to pressure and vibration stimuli. The signal conversion process uses mathematical functions reflecting the interspike interval of firing activity of single afferent fibers to convert slow adaptive sensor outputs to a slow adaptive-spike pattern mimicking output via a slow adaptive neural stimulator while fast adaptive neural stimulator outputs are designed to pulse outputs similarly to biological signals triggered at on-off contacts. The output current of the neural stimulator is adjustable from one microampere to ten milliamperes appropriate for visual perception peripheral nerves and sciatic nerves. To prove biological integration two animal experiments were designed including an ex vivo transmission test in an afferent nerve and an in vivo muscle response test through the stimulation of an efferent nerve. In the ex vivo test the saphenous nerve separated from the leg of a mouse was directly stimulated with signals from the T-skin system and the neural signals at the other end of the afferent nerve were recorded to verify proper transmission. The recording signals from slow adaptive and fast adaptive afferent nerves had the same pattern as the artificial signals transmitted from the T-skin system to real nerves. In the in vivo experiment the signal from the T-skin system was conveyed to the efferent nerve resulting in torque from leg movement by activation of the hindlimb muscle. The aspect related to torque showed separate response patterns corresponding to each type of mechanoreceptor where slow adaptive output torque had frequent spikes at higher intensities of static pressure while fast adaptive output torque generated spike patterns noticeable only at the beginning and end of the stimulus. Actuation of muscle also followed frequency stimuli from one to one hundred hertz showing that signals from the fast adaptive neural stimulator can be applied in biological systems. Surface texture recognition was demonstrated by mimicking the complex process mediated by spatial encoding of geometrical properties of coarse textures and vibrotactile encoding of fine textures. An artificial ridge structure mimicking the structure of a human fingerprint was laminated on the T-skin device to allow active exploration of tactile surfaces. A deep learning technique was introduced to classify surface textures where twenty fabrics with different textures were tested. After consecutive back-and-forth scanning with gentle contact pressure the T-skin system successfully classified the textures with ninety-nine point one percent accuracy after model training which was superior to the classification accuracy of either the slow adaptive or fast adaptive sensor alone. The combination of sensor signals enabled the detection of information on coarse textures arising from geometrical properties and fine-texture information induced by interacting vibration similarly to the human finger skin system. Furthermore textures of an unknown fabric were predicted by the T-skin system to confirm whether the device could perceive similar textures from the learned fabrics and while human tactile perception varied among participants the device classified the unknown fabric as a single fabric most similar to a prelearned fabric. The study concludes by reporting a bioinspired artificial neural tactile system fabricated by incorporating slow adaptive-mimicking reduced graphene oxide sheets and fast adaptive-mimicking barium titanate nanoparticles in a polymeric polydimethylsiloxane matrix providing sensors simultaneously sensitive to pressure and vibration. The system successfully mimics slow adaptive and fast adaptive type neural signal patterns and the synthesized output signals can be fully transmitted in real nerves or generate the synaptic transmission required to trigger muscle contraction. As an artificial finger fine and complex textures were learned and classified using a deep learning technique and an unknown texture was predicted on the basis of learned textures. Future studies may examine how the brain perceives signals from this system using sophisticated neural imaging and develop advanced algorithms to generate a database for neural signals ultimately aiming to overcome the limitations of conventional pressure or vibration-sensitive sensors leading to devices capable of improved reproduction of sense. The methodology involved purchasing reduced graphene oxide nanopowder and barium titanate nanopowder and mixing them with a polydimethylsiloxane base subjected to vortex mixing and sonication before adding a curing agent and thermal treatment at eighty-five degrees Celsius followed by poling using a ten kilovolt discharge voltage. Animal procedures were approved by institutional committees and conducted in accordance with national guidelines using male mice and rats housed under controlled conditions. Ex vivo single-fibre recordings were carried out on dissected hairy skin of the hindpaw innervated by the saphenous nerve perfused with synthetic interstitial fluid where spikes from single fibres were recorded extracellularly and distinguished by evoked action potential patterns. Spike generation models were developed to convert tactile sensor signals to slowly adapting spike trains using fifth-order polynomial functions fitted to interspike interval data of mouse afferent nerves. In vivo stimulation and muscle force recording involved anaesthetizing rats exposing the sciatic nerve and wrapping a stimulation electrode around it to measure torque responses using a torque sensor. Deep learning for classifying surface textures involved collecting electrical output signals over ten hours with a sampling frequency of one kilohertz during rubbing of fabric samples on the sensors. Noise signals were removed using the moving-average method and features were extracted by analysing power spectral density in the frequency domain. The training and test data ratio was set to seven to three and human tests were conducted in accordance with rules for human-related experiments prescribing physiological and neurological mechanisms of touch without applying dangerous stimuli.}
}

@article{garcia-perezForcedchoiceStaircasesFixed1998a,
  ids = {garcia-perezForcedchoiceStaircasesFixed1998},
  title = {Forced-Choice Staircases with Fixed Step Sizes: {{Asymptotic}} and Small-Sample Properties},
  shorttitle = {Forced-Choice Staircases with Fixed Step Sizes},
  author = {Garc\'\ia-P\'erez, Miguel A.},
  date = {1998-06},
  journaltitle = {Vision Research},
  shortjournal = {Vision Res.},
  doi = {10.1016/S0042-6989(97)00340-4},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This research paper by Miguel A. Garc\'ia-P\'erez presents a comprehensive simulation-based analysis of the asymptotic and small-sample properties of forced-choice staircases with fixed step sizes (FSS), addressing the widespread but theoretically unproven assumption that these adaptive procedures converge on specific percent-correct points dictated solely by their up/down rules as proposed by Wetherill and Levitt or Kaernbach. The introduction highlights that while FSS staircases are dominant in psychophysical literature, often constituting 68\% of 2AFC staircase studies, their descriptions are frequently incomplete, hampering replicability, and previous claims regarding their convergence targets have never been rigorously verified against variable step sizes and psychometric function spreads. To investigate these issues, the study employs extensive simulations utilizing Weibull psychometric functions across a factorial design involving four up/down rules (one-, two-, three-, and four-down/one-up), thirty-one relative step sizes, varying ratios of downward to upward step sizes, different starting values, boundary conditions, and function spreads, with dependent variables calculated primarily through averaging stimulus levels at reversal points. The asymptotic results demonstrate that convergence is predominantly determined by the relative magnitude of the steps compared to the psychometric function spread rather than the up/down rule itself, revealing that standard equal step sizes (\$D-/D+ = 1\$) fail to stabilize on presumed targets like 70.71\% or 79.37\% except under infinitesimal step conditions, whereas optimal ratios of \$D-/D+\$ (specifically 0.2845, 0.5488, 0.7393, and 0.8415) allow staircases to converge reliably on 77.85\%, 80.35\%, 83.15\%, and 85.84\%-correct points respectively regardless of absolute step size, provided a carry-on boundary condition is used instead of truncation to avoid distortions caused by physical limits. Furthermore, the analysis identifies that estimating threshold via the arithmetic mean of linear contrasts introduces bias and inefficiency, recommending instead the geometric mean of linear contrasts (equivalent to the arithmetic mean of log contrasts) to maintain consistency with the logarithmic nature of fixed step definitions. In the realm of small-sample characteristics, the study finds that short staircases comprising up to 20 reversals suffer from significant bias and imprecision unless the upward step size exceeds half the spread of the psychometric function (\$D+ {$>$} s/2\$), because smaller steps prevent the procedure from recovering from starting values located far below threshold, leading to substantial drift or erroneous estimates even when the asymptotic parameters are optimized. Based on these findings, the author formulates practical recommendations for experimenters, urging the adoption of large step sizes between \$s/2\$ and \$s\$, the implementation of unequal step downs according to the derived optimal ratios, the avoidance of one- and two-down/one-up rules with fewer than 20 reversals, the suppression of preliminary phases to maximize data collection time, and the use of well-above-threshold starting values to ensure subjects are aware of the stimulus, all while emphasizing the necessity of fully reporting staircase parameters including step sizes in constant units and boundary conditions to facilitate accurate replication and interpretation of psychophysical data.}
}

@article{greensponEvokingStablePrecise2024,
  title = {Evoking Stable and Precise Tactile Sensations via Multi-Electrode Intracortical Microstimulation of the Somatosensory Cortex},
  author = {Greenspon, Charles M. and Valle, Giacomo and Shelchkova, Natalya D. and Hobbs, Taylor G. and Verbaarschot, Ceci and Callier, Thierri and Berger-Wolf, Ev I. and Okorokova, Elizaveta V. and Hutchison, Brianna C. and Dogruoz, Efe and Sobinov, Anton R. and Jordan, Patrick M. and Weiss, Jeffrey M. and Fitzgerald, Emily E. and Prasad, Dillan and Van Driesche, Ashley and He, Qinpu and Liu, Fang and Kirsch, Robert F. and Miller, Jonathan P. and Lee, Ray C. and Satzer, David and Gonzalez-Martinez, Jorge and Warnke, Peter C. and Ajiboye, Abidemi B. and Graczyk, Emily L. and Boninger, Michael L. and Collinger, Jennifer L. and Downey, John E. and Miller, Lee E. and Hatsopoulos, Nicholas G. and Gaunt, Robert A. and Bensmaia, Sliman J.},
  date = {2024-12-06},
  journaltitle = {Nature Biomedical Engineering},
  shortjournal = {Nat. Biomed. Eng},
  doi = {10.1038/s41551-024-01299-z},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This research paper presents a comprehensive study on evoking stable and precise tactile sensations via multi-electrode intracortical microstimulation (ICMS) of the somatosensory cortex in three participants with cervical spinal cord injury, addressing critical questions regarding the long-term stability of projected fields and the functional utility of ICMS for bionic hand control. Conducted under an investigational device exemption involving participants C1, P2, and P3 alongside a clinical trial participant R1, the study utilized Blackrock Neurotech microelectrode arrays implanted in Brodmann's area 1 of the somatosensory cortex and the motor cortex, allowing for the characterization of ICMS-evoked percepts over periods spanning two to seven years. Longitudinal analysis of projected fields (PFs) revealed that these percepts are highly stable, typically comprising a focal hotspot with diffuse borders that remain consistent over time, although slight drifts were noted in participant P2, with variability within a single day matching variability across years, and aggregate centroids providing reliable estimates of underlying PF location. Somatotopic mapping confirmed that PF locations align with the canonical homunculus along the mediolateral axis parallel to the central sulcus, with a systematic relationship where a two-millimeter shift in cortex corresponds to a ten-millimeter shift on the skin, and comparisons with natural receptive fields demonstrated that ICMS activates a smaller, more specific neuronal population, with PFs occupying roughly one-sixth to one-seventh of the size of natural receptive fields and falling almost entirely within them. The investigation into stimulus parameters showed that PF size and perceived intensity increase with both amplitude and frequency, yet the dynamic range of single-electrode ICMS is limited, offering only two to fourteen discriminable force levels compared to forty-five to fifty in natural touch, primarily constrained by safety limits on charge density and the non-linear scaling of mechanical perception. To enhance performance, the authors demonstrated that stimulating multiple electrodes simultaneously results in additive percepts that are more focal and significantly easier to localize, reducing localization errors in robotic digit tasks from thirty percent with single electrodes to zero percent with multi-electrode stimulation, while magnitude estimation experiments confirmed that perceived magnitude scales linearly with ICMS amplitude but follows a power law for mechanical stimuli. Moreover, the use of biomimetic stimulation patterns, which emphasize contact transients, improved amplitude discrimination sensitivity and increased discriminable levels, while multi-electrode biomimetic stimulation expanded the dynamic range to approximately two Newtons without increasing charge per phase, thereby mitigating risks of neuronal damage associated with high charge densities. In a closed-loop compliance discrimination task using a sensorized Ability Hand, multi-electrode biomimetic feedback significantly outperformed single-electrode linear feedback, achieving a seven point five percent error rate versus twenty-five percent, and psychometric functions indicated that JNDs followed Weber's law on average despite electrode-specific variations, ultimately establishing that multi-electrode ICMS combined with biomimetic encoding provides a robust solution for restoring stable, precise, and behaviorally relevant tactile feedback necessary for dexterous use of brain-controlled bionic limbs.}
}

@article{handlerMechanosensoryNeuronsTouch2021,
  title = {The Mechanosensory Neurons of Touch and Their Mechanisms of Activation},
  author = {Handler, Annie and Ginty, David D.},
  date = {2021-09},
  journaltitle = {Nature Reviews Neuroscience},
  shortjournal = {Nat. Rev. Neurosci.},
  doi = {10.1038/s41583-021-00489-x},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: Touch lies at the heart of our interaction with the world, enabling perception of environmental forces through a preponderance of mechanically sensitive neurons residing within the integumentary system. In mammals, the cell bodies of cutaneous mechanosensory neurons reside within dorsal root ganglia and trigeminal ganglia, giving rise to axons that branch into distal cutaneous projections where mechanical forces are transformed into electrical signals. These sensory neurons are categorized by preferred mechanical stimulus, force threshold, adaptation rate, and conduction velocity, with low-threshold mechanoreceptors responding to innocuous forces and high-threshold mechanoreceptors mediating painful stimuli. Central to understanding touch is knowing how biomechanical properties of end organs and mechanotransduction machinery lead to spike patterns in LTMRs, a field that has seen an explosion of understanding in the past decade due to advances in genetic tools and imaging methods. Recent reviews summarize advances in defining mammalian LTMR properties, principal mechanosensitive proteins, and the morphological features of end organs that influence subtype-specific tuning. Within individual animals and across species, there are morphologically distinct skin regions such as hairy skin, glabrous skin, and specialized regions like whisker pads, which differ in tactile sensitivity and sensorimotor circuitry. Despite this range, much knowledge comes from studies of glabrous digit and trunk hairy skin, where LTMRs are diverse with notably distinct physiological properties. Broadly classified by conduction velocity, heavily myelinated A{$\beta$}-LTMR nerve fibres propagate action potentials at roughly 15--100 m s{$^{-1}$}, while lightly myelinated A{$\delta$}-LTMRs and unmyelinated C-LTMRs conduct at intermediate and slow velocities respectively. LTMRs also differ in adaptation rates, with slowly adapting A{$\beta$}-LTMRs exhibiting spiking throughout sustained indentation and rapidly adapting A{$\beta$}-LTMRs firing only at the onset or end of indentation. Receptive field properties further distinguish subtypes, as only RA-LTMRs grow with increasing force, and while some RA-LTMRs have well-defined restricted fields, others like those associating with Pacinian corpuscles can span nearly the entire hand. Furthermore, while LTMRs can spike in a temporally phase-locked manner to periodic stimuli, the force threshold for activation of Meissner and Pacinian RA-LTMRs is uniquely frequency dependent, rendering each subtype suitable to convey distinct features of a tactile stimulus to the CNS. End organ structures housing LTMR terminals provide additional classification means, with A{$\beta$} SAI-LTMRs forming Merkel cell--neurite complexes, A{$\beta$} RAI-LTMRs associating with Meissner corpuscles, and A{$\beta$} RAII-LTMRs terminating within Pacinian corpuscles. In contrast, hairy skin innervating A{$\beta$} RA-LTMRs form longitudinal lanceolate endings enveloping hair follicles, while A{$\beta$} SAI-LTMRs associate with touch domes containing groups of Merkel cells. Additionally, the A{$\beta$} field-LTMR exhibits an expansive axon forming circumferential endings wrapping around hair follicles, being highly sensitive to gentle stroke but insensitive to hair deflection. Two additional LTMR subtypes, rapidly adapting A{$\delta$}-LTMRs and slowly adapting C-LTMRs, exclusively innervate hairy skin forming lanceolate endings, while the A{$\beta$} SAII-LTMR innervates both skin types and may form Ruffini corpuscles, though this relationship remains debated. Individual LTMR endings often exhibit spatially tiled arrangements, pointing to a population coding model where tactile appreciation arises from central integration of impulses from different LTMR subtypes. Central to understanding sensory systems is appreciating how stimuli are detected and converted into electrical signals, involving biomechanics of skin, force propagation, and proteins forming mechanoelectrical transduction channels. Recent breakthrough findings revealed that the mechanically sensitive cation channel PIEZO2 is the principal mechanotransduction channel in both slowly and rapidly adapting mammalian LTMRs, with lacking PIEZO2 resulting in profound deficits in light touch sensation. Despite this, understanding how cutaneous stress is filtered through the epidermis and dermis remains limited, and additional proteins like stomatin-like protein 3 are likely to play roles in scaffolding PIEZO2 or modulating tactile responses. The Merkel cell--neurite complex resides at the dermal--epidermal boundary, consisting of A{$\beta$} SAI-LTMR terminal endings closely associated with Merkel cells in the stratum basale. In response to sustained indentation, the A{$\beta$} SAI-LTMR exhibits two physiological response phases: an initial dynamic phase changing rapidly with force amplitude and velocity, and a second force amplitude-dependent steady-state phase maintained for extended periods. This capacity for high-frequency firing may arise from rapid activation kinetics of voltage-gated channels and tension-activated potassium channels expressed along axons. The complex responds to discontinuities in texture, suggesting shear stress influences receptor elements alongside vertical compression. Genetic access using TrkC and ATOH1 tools has enabled characterization showing single A{$\beta$} SAI-LTMR axons branching to associate with clustered Merkel cells, with asymmetric distribution potentially underlying non-uniform receptive fields. Morphological features include desmosomes anchoring Merkel cells to keratinocytes and lamellar cells securing the axon terminal to the basement membrane, cushioned by collagen fibrils. Recent work investigated whether Merkel cells play an active role in mechanotransduction, revealing similarities to synapses and evidence for glutamatergic communication, though optogenetic depolarization of Merkel cells can elicit action potentials in A{$\beta$} SAI-LTMRs. Electrophysiological recordings demonstrated inherent mechanosensitivity in Merkel cells, with PIEZO2 deletion disproportionately impairing the sustained response during the static phase. These findings suggest an excitatory connection with a two-site model implicating the LTMR afferent as the initial site of transduction for the dynamic phase and Merkel cells for the sustained static phase. The Pacinian corpuscle has served as a model for studying mechanotransduction due to its large size and prevalence, found in the deep dermis of both glabrous and hairy skin. Its A{$\beta$} RAII-LTMR responds to the dynamic phase of static indentation with rapid adaptation and possesses enormous receptive fields spanning nearly half the human hand. Unlike other LTMR subtypes, it exhibits impressive filtering of low-frequency stimuli, enabling high-fidelity responses to high-frequency dynamic light forces. Proper development depends on the transcription factor MAF, and the structure reveals a single Ret-expressing axon surrounded by semi-annular cytoplasmic lamellae originating from Schwann cells and perineurial cells. Vesicles within the axon suggest strain along protrusions may initiate chemical communication, and the outer core region is under turgor pressure, attribute central to physiological responsivity. Classic experiments localized the mechanoreceptor to the unmyelinated portion of the axon, suggesting spatial summation of electrical activity, though whether receptor potentials are generated along the entire length or specifically within axonal protrusions remains unknown. While naked axon retains mechanoreceptive properties, characteristic rapid adaptation is lost without lamellar processes, suggesting they create a biomechanical filter influencing neural responses. Modeling suggests mechanics of lamellar processes may amplify oscillatory strain, and turgor pressure is likely essential for maintaining response to high-frequency vibrations. Beyond biomechanical roles, lamellar cells are hypothesized to release GABA leading to inhibition during static phases. The Meissner corpuscle, invariantly located at the apex of dermal papillae in glabrous skin, is closest to the skin surface and renders resident A{$\beta$} RAI-LTMRs exquisitely sensitive to skin deformation. Although smaller than Pacinian corpuscles, A{$\beta$} RAI-LTMRs share functional properties like frequency dependence in force sensitivity but are optimally tuned to light forces in the 40--60 Hz range, suggesting a role in sensing microslips. Recent genetic labelling found two molecularly distinct A{$\beta$}-LTMR subtypes within most murine Meissner corpuscles, a TrkB-expressing population and a Ret-expressing population, with the former matching stereotypical highly sensitive A{$\beta$} RAI-LTMRs and the latter less sensitive with greater variability. Single-unit recordings revealed these subtypes increase coding capacity, and they exhibit homotypic tiling with offset receptive fields. Within the corpuscle, interdigitated LTMR axons take a tortuous path, shedding myelination to form close associations with lamellar cells studded with caveola-like pits. Comparative analysis indicated more lamellar wrappings are associated with highly sensitive TrkB+ afferents, suggesting a role for lamellar processes in setting responsivity. While direct evidence of PIEZO2's role in transducing forces within the corpuscle is lacking, histological and functional experiments point to a role in mediating responses, and recent evidence suggests Meissner corpuscle lamellar cells play a critical role with the tether-like protein USH2A necessary for low-frequency vibration tuning. Hairy skin LTMRs form associations with hair follicles extending touch perception, with complexity involving unique hair follicle types innervated by unique combinations of LTMR subtype endings. Guard, awl/auchene, and zigzag hairs receive innervation from distinct invariant combinations of A{$\beta$} RA-LTMRs, A{$\delta$}-LTMRs, and C-LTMRs, each forming fence-like lanceolate endings running parallel to the hair shaft. While hairy skin A{$\beta$} RA-LTMRs and A{$\delta$}-LTMRs rapidly adapt to indentation, all three are highly sensitive to hair deflections and skin stroke, assuming the lanceolate ending structure endows robust sensitivity. Expression of T-type calcium channels selectively in A{$\delta$}-LTMRs and C-LTMRs may contribute to low excitability thresholds, and the polarized organization of A{$\delta$}-LTMR lanceolate endings renders them uniquely direction sensitive. Unique among LTMR subtypes are C-LTMRs initially hypothesized for tickling but recently shown to respond to intermediate stroke velocities linked to social and emotional aspects of touch. Each lanceolate-forming LTMR subtype is unique in terminal area and total number of hair follicles innervated, permitting distinct patterns of signal integration. The lanceolate complex is embedded within a matrix of longitudinally oriented collagen fibrils sandwiched between epithelial cells and distal circumferential collagen matrix, with TSC membranes studded with caveola-like invaginations. Intermittent associations between TSC processes leave portions of lanceolate axon membrane exposed, suggested to serve as a site of mechanotransduction, with fine filaments potentially serving as tethers and N-cadherin adherens junctions enriched along boundaries. Scanning electron microscopy revealed numerous axonal processes emanating from the central lanceolate axon on the side distal to the hair shaft, though their role is unexplored. Unique among LTMR subtypes are the A{$\beta$} field-LTMRs described first in the 1960s, unique due to large non-punctate receptive fields, relatively high threshold for indentation, and insensitivity to hair deflection. Physiological properties consistent with being A{$\beta$}-HTMRs, yet single-unit recordings revealed exquisite sensitivity to gentle stroke across large areas of skin. At indentation forces near threshold, responses are rapidly adapting while higher forces are intermediately adapting. Genetic access related physiological properties to axon terminal structure, where cutaneous endings associate with hair follicles but form circumferential endings embedded within circumferentially oriented collagen matrix just distal to lanceolate complexes, winding like a corkscrew around the follicle. Insensitivity to hair deflection arises from lack of intimate association with outer root sheath epithelial cells, contrasting with proximal lanceolate endings sensitive to slight movement. Large receptive fields span 3--4 mm{$^2$} with stimulation hotspots separated by insensitive regions, aligning with spatial innervation pattern where each neuron innervates between 20 and 180 hair follicles. Spike initiation sites are localized far from terminal circumferential endings, pointing to a model where subthreshold integration leads to spike initiation. The elusive A{$\beta$} SAII-LTMRs are slowly adapting neurons with early dynamic and sustained static phases linked by adaptation, exhibiting more regular interspike intervals and often baseline firing in absence of stimulus. Their receptive field is roughly five times larger than Merkel cell-associated A{$\beta$} SAI-LTMRs, and although six times less sensitive to indentation, they are more sensitive to skin stretch. They may be directionally sensitive, excited by stretch along one axis and silenced at 90{$^\circ$} offset, suggesting a role in perception of hand and finger orientation. Early work suggested termination within Ruffini corpuscles, defined as structures encasing single axons branching to form terminals associated with longitudinally oriented collagen bundles, surrounded by a perineurial capsule retaining fluid. Unencapsulated Ruffini-like endings have been described at base of fingernails or claws and surrounding teeth, yet recordings in mice and humans have failed to identify Ruffini corpuscles within expected skin regions. Identification of molecular markers and characterization of end organ structures will aid clarifying their role. Across the surface of the body there are anatomically and physiologically distinct skin regions specialized for detection and discrimination of tactile forces. Decades of histological examination revealed distinct end organ types, only recently has genetic access enabled detailed analysis of tuning and adaptation properties varying across afferents. With advances and the seminal discovery of PIEZO2, understanding how cutaneous forces transform into electrical signals is now within reach. Appreciating precise subcellular localization of PIEZO2 and additional components will aid understanding of how skin indentation, hair deflection, stretch, and vibration gate PIEZO2. Transcriptomic analysis has revealed genes differentially expressed across subtypes promoting discovery of new classes, and experiments using genetically encoded calcium sensors coupled with multiplexed in situ hybridization allow comparison of transcriptomic classes with functional responses. While datasets enable targeted generation of driver lines, few molecular distinctions fully account for diversity of physiological properties, underscoring the prominent role of end organ structure and biomechanics. Complementing physiology with three-dimensional reconstructions and precise localization of transduction machinery is likely to reveal how receptors generate action potential patterns. Historically, LTMR afferents were classified as primary receptors with Schwann cells filtering forces, supported by PIEZO2 presence in Meissner corpuscle axons but not lamellar cells. However, recent work points to epithelial Merkel cells, keratinocytes, and Schwann cells as key players, showing inherent mechanosensitivity of non-neuronal cells. Further experiments are needed to determine if cutaneous lamellar cells can initiate mechanical responses and clarify communication nature. Genetic access has advanced research into an era where cellular, physical, and molecular determinants are being addressed. Moving forwards, insight into touch sensors in specialized skin regions should become a focus, as little is known about end organ structures within nipples despite their role in milk let down. Some species evolved specialized skin regions like Grandry and Herbst corpuscles of duck bills and Eimer organs of star-nosed moles resembling human structures, revealing conservation in receptor structures. Distinct organization of end organ structures in tactile foraging specialists suggests variation in structure, location, and density serves as evolutionary solution to meet somatosensory demands. Expanding comparative analyses will provide clues to mechanisms of tactile transduction. Finally, percipience for heterogeneous properties of LTMRs is rooted in single-unit recordings during controlled stimuli, but appreciation for engagement during dynamic naturalistic touch is needed. Increased coding efficiency in vision and hearing has been demonstrated using naturalistic stimuli, and any particular innocuous tactile stimulus can likely be represented by unique combination of cutaneous end organs. Understanding basis of touch requires in-depth appreciation of how each LTMR subtype gains distinct firing pattern and how subtypes respond collectively during naturalistic touch. Experiments using complex naturalistic tactile stimuli have revealed logic of compound neural activity patterns evoked across various LTMR subtypes. On top of this, HTMR populations likely contribute to detection of innocuous touch forces, yet relatively little is known about activation and contribution. Use of in vivo calcium or voltage imaging across LTMR and HTMR subtypes using naturalistic stimuli will aid understanding of how features are differentially represented and how populations are engaged by innocuous and painful touch. Together, this global picture of how mechanically sensitive neurons respond to innocuous touch will move closer to understanding how disparate yet concerted activities integrate to engage central circuits and give rise to sense of touch.}
}

@article{hasegawaAcousticRadiationForceSolid1969,
  title = {Acoustic-Radiation Force on a Solid Elastic Sphere},
  author = {Hasegawa, Takahi and Yosioka, Katuya},
  date = {1969-11-01},
  journaltitle = {Journal of the Acoustical Society of America},
  shortjournal = {J. Acoust. Soc. Am.},
  doi = {10.1121/1.1911832},
  issue = {5B},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: The acoustic radiation force on a solid sphere suspended freely in a plane progressive sound field is calculated taking into account the elasticity of the sphere, revealing that the radiation force versus ka curve, where ka represents the radius times the wavenumber in the surrounding medium, exhibits sharp maxima or minima corresponding to resonances in every normal mode of free vibration of the sphere, with laboratory measurements showing good agreement with the theory and indicating that the accuracy of absolute acoustic-intensity determination by the radiation-force method will be improved by using this present theory instead of King's. While King's formula for the radiation force on rigid spheres has been the basis for determining absolute ultrasonic intensity by the radiation-force method, experiments in the authors' laboratory showed distinct evidence of the effect of the elasticity of steel or brass spheres on radiation force, leading this paper to treat the acoustic-radiation force on a solid sphere taking the elasticity of the sphere into account with assumptions that the sound field is plane progressive, the solid sphere is isotropic and elastic, and the surrounding fluid is nonviscous, wherein Section I calculates the scattering of plane progressive waves by a solid elastic sphere, Section II determines the radiation force acting on the solid elastic sphere, Section III provides examples of numerical evaluation and comparisons with experiments, and Section IV discusses problems in applying the present theory to the determination of absolute acoustic intensity. In Section I regarding the scattering of plane waves by a solid elastic sphere, plane progressive sound waves of frequency omega divided by two pi are incident upon a sphere of isotropic solid elastic material immersed in a nonviscous fluid medium with the center coinciding with the origin of a rectangular coordinate system, where the equation of motion in a solid isotropic elastic medium is given involving Lame's constants and density, assuming displacement derived from a scalar potential and a vector potential expressed in spherical coordinates involving Legendre polynomials and spherical Bessel functions, while the velocity potential of the incident plane progressive waves propagating in the direction of the z axis is represented by a series expansion involving spherical Bessel functions. The velocity potential outside the sphere is written as the sum of incident and scattered waves, with the scattered potential expressed using spherical Hankel functions of the second kind and a constant to be determined by boundary conditions which include the sum of pressure in the fluid and normal component of stress being zero, equality of normal displacement components, and zero tangential shearing stress, leading after laborious calculations to a scattering coefficient form involving derivatives of Bessel functions where the result is identical to Faran's earlier calculation though expressions differ slightly, allowing the determination of the real and imaginary parts of the coefficient using spherical Bessel functions of the second kind. Section II addresses the acoustic-radiation force on a solid elastic sphere, calculating the force on a boundary moving with small velocity of the first order using a formula involving time averages of velocity potentials and particle velocities, where when the boundary is spherical and the acoustic field is axially symmetrical, the radiation force along the axis is given by the sum of four components involving integrals of pressure and velocity potential derivatives with respect to radial and angular coordinates. By substituting the previously derived wave equations into the potential expression, the velocity potential is obtained in a form involving coefficients U sub n and V sub n, from which the real part is extracted to substitute into the force component equations using time average relations, finally yielding explicit expressions for the components of the radiation force involving sums over n of products of U sub n and V sub n and their derivatives, alongside the definition of mean energy density in the plane progressive sound field. A dimensionless quantity Y sub v is defined as the radiation force per unit cross section and unit mean energy density, referred to as the acoustic radiation force function of the sphere for the plane progressive sound field, with numeric evaluations made of this function having a specific form involving summations of terms dependent on the order n and the arguments of the Bessel functions multiplied by factors of x equals ka. In Section III comparing theory and experiment, the acoustic radiation force function Y sub v was evaluated for spheres of brass, steel, and stainless steel using physical constants listed in Table I, assuming the surrounding fluid was water, with results shown by solid curves in Figures 2, 3, and 4 respectively, where the broken curve in each figure represents King's curve for rigid spheres of the same density, showing that Y sub v begins at small values of ka as though the solid were a rigid body but deviation from King's curve appears with increasing ka and shows a number of sharp maxima or minima corresponding to resonance in every normal mode of the free vibration of the sphere such as pulsation and spheroidal vibration indicated by numbers below arrows in the figures. The marks in each figure represent the relative values of measured Y sub v normalized to agree with the theoretical curve at a certain value of ka, with normalization points specified for each figure, linking radiation forces measured at different frequencies by assuming Y sub v values are the same for the same values of ka, all measurements made in the frequency range 470 kHz to 1 MHz under field conditions eliminating departure from plane progressive fields, with the agreement between the present theory and experiments considered satisfactory and deviations from King's curve attributed to the effect of elastic vibration of the sphere. Regarding the difference in radiation force between brass and steel spheres, previous experimental results show that while King's theory predicts practically the same magnitude for both, the experiment shows the former as larger than the latter by 20\% to 30\% in the range of ka 2.0 to 4.5, which values are quite in accordance with the present theory, and computed values of Y sub v for stainless steel spheres are listed as a function of ka in Table II for use in acoustic-intensity determination. Section IV discusses application to acoustic-intensity determination, noting that because of the influence of King's theory there has been no conclusive restriction on the radius of the sphere used in the radiation-force method, however, calculation shows spheres whose radii are near those of resonance in the normal modes are not advisable since the Y sub v-versus-ka curves are too sharp, defining unsuitable ranges of ka for stainless steel and steel where resonance occurs, stating the brass curve is too irregular to permit use of this material for intensity determination, while for other ka's all experimental points fit the present calculation quite well, suggesting better accuracy will be attained by using the present theory for intensity computation than by using King's theory. The advisable ranges of ka are specified as 2.2 to 4.2 and 5.5 to 6.5 for stainless steel, and 2.2 to 4.5 and 6.0 to 7.0 for steel, while noting that minor shifts of the acoustic intensity determined from the real level arising from unknown causes are beyond the scope of this paper. Finally, the Summary reiterates that the acoustic-radiation force on a solid sphere suspended freely in a plane progressive sound field was calculated taking the elasticity of the sphere into account, with the curve of radiation force versus ka showing sharp maxima or minima corresponding to resonance in every normal mode of free vibration, confirming that measurements conducted in the laboratory were in good agreement with the theory, advising that it is not advisable to use spheres whose ka values are close to those corresponding to the resonance of the free vibration of the sphere for intensity determination, providing suitable ranges of ka for intensity determination, and concluding that the absolute acoustic intensity determined by using the result of the present theory is closer to the real level than that obtained from King's theory for rigid spheres.}
}

@article{holmesPostprocessingFullMatrix2005,
  title = {Post-Processing of the Full Matrix of Ultrasonic Transmit--Receive Array Data for Non-Destructive Evaluation},
  author = {Holmes, Caroline and Drinkwater, Bruce W. and Wilcox, Paul D.},
  date = {2005-12},
  journaltitle = {NDT \& E International},
  shortjournal = {NDT \& E Int.},
  doi = {10.1016/j.ndteint.2005.04.002},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: The research paper titled Post-processing of the full matrix of ultrasonic transmit--receive array data for non-destructive evaluation by Caroline Holmes, Bruce W. Drinkwater, and Paul D. Wilcox presents an investigation into alternative data processing methods for ultrasonic phased array systems used in non-destructive evaluation (NDE), contrasting the traditional reliance on parallel transmission circuits for real-time wavefront control with a novel approach utilizing offline post-processing of the complete full matrix capture (FMC) of time-domain signals. The authors argue that while conventional phased array systems emulate monolithic transducers through staggered firing of independent parallel circuits to generate real-time B-scans, modern computer power enables the efficient analysis of large datasets comprising all combinations of transmit and receive element signals, thereby offering increased sensitivity to small defects and greater inspection coverage without the need for hardware reconfiguration. The primary aims of the study are to define the underlying mathematics and practical implementation of four distinct post-processing algorithms---specifically the plane B-scan, focused B-scan, sector B-scan, and the total focusing method (TFM)---to perform side-by-side quantitative comparisons of these techniques, and to demonstrate that the TFM outperforms other methods by focusing the beam at every point in the target region during both transmission and reception. To facilitate this assessment, a two-dimensional simulation program written in Matlab was employed to model the generation of the full matrix of array data for a linear array transducer with 64 equi-spaced elements operating at 5 MHz in aluminium, calculating propagation distances and applying phase shifts, directivity functions, and inverse power laws to account for beam spread and element characteristics while accounting for data redundancy inherent in reciprocal transmit-receive paths. The implementation section details how the plane B-scan sums signals from adjacent aperture elements to produce a planar beam that is electronically shifted along the array, whereas the focused B-scan introduces specific time delays at transmission and reception stages to create high-intensity focal zones, and the sector B-scan steers the beam through an angular sweep using all elements, all of which emulate standard inspection methodologies but are implemented here as subsets of the full matrix data. In contrast, the TFM algorithm discretises the target region into a grid and sums signals from all possible transmitter-receiver pairs to synthesize a focus at every point, utilizing the maximum amount of available information for each pixel in the image, albeit constrained primarily by computational time rather than hardware limitations. To quantify the performance of these algorithms, the authors introduce an Array Performance Indicator (API), defined as the dimensionless area within which the point spread function exceeds K6 dB down from its maximum value, normalized to the square of the wavelength, which serves as a metric for spatial resolution and detection capability. Simulation results utilizing this API metric reveal that while focused B-scans improve resolution over plane scans, the TFM offers a substantial reduction in API, indicating superior resolution and a significantly larger imaging area that extends beyond the edges of the array, with contour maps showing circular regions of constant API governed by the aperture angle. Experimental validation was subsequently conducted using a custom-designed matrix array controller and a digital storage oscilloscope to capture 2080 time-domain signals from aluminium blocks containing EDM notches that served as point reflectors at varying depths, with the experimental data showing good quantitative agreement with the simulated models, evidenced by a 14\% difference in API values attributed to bandwidth discrepancies between the simulated and physical signals. The experimental results confirmed that the TFM achieved an API approximately half that of the focused B-scan and demonstrated significantly better signal-to-noise ratios when combined with signal averaging, although the authors acknowledge that the single-element transmission inherent in FMC can limit total acoustic power output and degrade SNR relative to traditional multi-element aperture approaches. Despite these SNR challenges, the study concludes that full matrix capture allows for the emulation of any beam-forming scheme through offline post-processing, enabling advanced NDE processing techniques such as tandem probes and time of flight diffraction on the same auditable raw data without the need for further experiments. Furthermore, the authors discuss the feasibility of FMC in commercial systems, noting that while the time required is physically limited by the pulse-repetition frequency and the number of elements, it is comparable to conventional swept B-scans, particularly if parallel reception is utilized, and anticipate that advances in dedicated hardware will soon render the processing time negligible compared to acquisition time. Ultimately, the paper establishes that the total focusing method offers significant performance advantages for NDE by maximizing the utility of the full matrix data, providing superior focusing capabilities across the entire target volume, and ensuring that the captured data remains fully flexible for future analysis.}
}

@incollection{hoshiIntroductionUltrasonicMidair2022,
  title = {Introduction to Ultrasonic Mid-Air Haptic Effects},
  booktitle = {Ultrasound {{Mid-Air Haptics}} for {{Touchless Interfaces}}},
  author = {Hoshi, Takayuki},
  editor = {Georgiou, Orestis and Frier, William and Freeman, Euan and Pacchierotti, Claudio and Hoshi, Takayuki},
  date = {2022},
  publisher = {Springer International Publishing},
  location = {Cham},
  doi = {10.1007/978-3-031-04043-6_1},
  langid = {english},
  note = {Paper Summary: This chapter serves as a comprehensive introduction to the fundamental physical principles governing ultrasonic mid-air haptics, aiming to facilitate a holistic understanding for researchers, engineers, and designers entering the field by dividing the discussion into four primary sub-topics: acoustic radiation pressure, phased array focusing, vibrotactile stimulation, and the mitigation of byproduct audible sounds. The introduction establishes the necessity for a theoretical grasp of these underlying mechanisms, assuming simplified and idealized conditions to describe phenomena from a theoretical standpoint while noting that practical hardware complexities and approximations are deferred to other chapters. The first major principle discussed is acoustic radiation pressure, which acts as the force originating on the skin surface due to high-intensity sound waves being blocked or reflected. Mathematically, this pressure P is expressed as proportional to the acoustic energy density E or the square of the sound pressure p, specifically P equals alpha times p-squared divided by rho-c-squared, where alpha ranges from one to two depending on surface reflection properties, with skin reflecting nearly all incident ultrasound. This effect requires high sound pressure levels, approximately 140 dB or more, to become perceptible because the pressure is too small to be felt at lower intensities. To provide physical intuition beyond the equation, the text derives acoustic radiation pressure using the kinetic theory of gases, modeling air as an ideal gas of particles colliding with a surface, demonstrating that the pressure originates from the product of momentum and the number of particles rebounding rather than energy density alone. Furthermore, the derivation accounts for diagonal incidence, showing that the normal force scales with the cosine squared of the incident angle theta while the total force applied scales with the cosine of theta due to the increased surface area receiving the beam. In addition to static pressure, the chapter introduces acoustic streaming, a nonlinear phenomenon where high-amplitude waves generate a laminar to turbulent flow in the medium, causing users to perceive a sense of wind alongside the radiation pressure. The second core topic addresses how high-intensity ultrasound is generated, contrasting conventional bolt-clamped Langevin-type transducers with phased arrays comprising hundreds of transducers that utilize phase control and superposition to create focal points capable of reaching sufficient intensity, such as 162 dB achieved with 285 transducers compared to 178 dB with a reflective concave setup. For phased array focusing, the spatial distribution of sound pressure on the focal plane is described by a sinc function derived from the interference of waves from an N-by-N square lattice array, where the main lobe diameter w is determined by the wavelength lambda, focal length r, and array size Nd. The text notes that while the main lobe is surrounded by weaker side lobes often ignored, the shape of the focal point varies with array geometry, such as an Airy pattern for circular arrays, and possesses a focal depth delta that alleviates the need for precise depth control. A critical consideration in array design is the generation of grating lobes when the transducer interval exceeds the wavelength, which can produce large amplitude regions comparable to the main lobe, though their impact is mitigated by transducer directivity and incident angle reductions, with non-periodic arrangements offering a trade-off between grating lobe suppression and output power. The capability to generate multiple focal points simultaneously is also outlined via a matrix equation mapping transducer signals to desired focal parameters, utilizing pseudo-inverse solutions often requiring regularization for optimization. Moving to human perception, the chapter explains that continuous application of radiation pressure leads to nerve adaptation, necessitating amplitude modulation AM of the ultrasound to induce vibrotactile sensations that align with mechanoreceptor sensitivity ranges of 10 to 500 Hz, typically utilizing 100 to 200 Hz modulation frequencies which influence perceived texture and focal point size. The fourth topic concerns audible sound radiation, a significant side effect arising because the modulation frequencies overlap with the human audible range. This noise stems from self-demodulation, where the nonlinearity of air demodulates the intense modulated ultrasound into audible frequencies, governed by a differential equation involving the second time derivative of the squared sound pressure, resulting in radiated sound dependent on the modulation frequency squared. To suppress this noise, the text suggests minimizing waveform complexity and lowering modulation frequencies, while lateral modulation offers a less noisy spatial control alternative. Additionally, audible artifacts occur during focal point movement due to transient amplitude dips caused by resonant phase switching, which can be suppressed by gradually changing the phase over multiple cycles to reduce noise by approximately 10 dB without significantly impacting haptic performance given the millisecond-scale transition times. The conclusion reiterates that these phenomena, explained through mathematical equations and physical argumentation, form the basis for advancing mid-air haptic technology, encouraging multidisciplinary research in hardware, software, and experience design. Finally, the appendix provides a detailed mathematical derivation of the spatial distribution of ultrasound on the focal plane, utilizing coordinate systems, Fresnel approximations, and geometric series summations to confirm the sinc function relationship established in the main text.}
}

@inbook{howardUltrasoundMidairTactile2022,
  title = {Ultrasound Mid-Air Tactile Feedback for Immersive Virtual Reality Interaction},
  booktitle = {Human--{{Computer Interaction Series}}},
  date = {2022},
  publisher = {Springer International Publishing},
  location = {Cham},
  doi = {10.1007/978-3-031-04043-6_6},
  bookauthor = {Howard, Thomas and Marchal, Maud and Pacchierotti, Claudio},
  langid = {english},
  note = {This chapter focuses on the integration of ultrasound mid-air haptic (UMH) devices into immersive virtual reality (VR) interaction, exploring three main axes: device integration, stimulus perception, and rendering of virtual environment (VE) properties, within the context of the state of the art in UMH for augmented and virtual reality. The introduction highlights the significance of haptic feedback in enhancing interaction, realism, and immersion in VR, emphasizing that UMH devices offer unique advantages such as not requiring users to be tethered to or wear any device, thus freeing the hands for concurrent interactions, simplifying tracking, and avoiding physical constraints that might break immersion. It also outlines the HCI interaction loop in VR, where UMH feedback needs to be integrated with other input and feedback devices without interference, while noting that current VR does not occlude real-world touch perceptions but overlays them with virtual haptic inputs. The state of the art and challenges section reviews early and recent applications of UMH in augmented reality (AR) and VR, such as touchable holograms and VR gaming, and identifies key challenges in integrating UMH into VR, including device integration (ensuring UMH devices do not impede input/output and cover the VR workspace), stimulus perception (understanding how users perceive UMH stimuli to guide design), and rendering (determining which VE properties can be rendered and how to do so effectively). The device integration section discusses the need for UMH devices to coexist with input devices (ensuring unobstructed skin for both tracking and haptic feedback, with optical tracking being a common solution) and feedback devices (maintaining co-location and synchronization with visual, auditory, and other haptic stimuli, while avoiding unintended stimuli), and presents PUMAH, a robotic solution that extends the UMH workspace through pan and tilt movements, enabling a 14-fold increase in workspace volume and supporting various VR use-cases like touchable holograms and haptic table-tennis. The perception of UMH stimuli section addresses the lack of knowledge about UMH stimulus perception, introducing the DOLPHIN framework, an open-source tool that simplifies stimulus design and perceptual evaluation by controlling geometric shape and sampling strategies (spatial discretization, temporal order, and intensity modulation), and summarizes psychophysical experiments on perceptual thresholds, finding that the 50\%-detection threshold for a single amplitude-modulated (AM) focal point is around 48.7-49.5\% intensity ({$\approx$}560 Pa) and largely independent of hand movement. The rendering section, building on the above, explores methods to render VE properties such as geometric details and stiffness sensations using spatiotemporal modulation (STM) with amplitude variations along focal point paths, leveraging insights from perceptual studies and the DOLPHIN framework to inform effective rendering schemes. Overall, this work, funded by the EU's H2020 H-Reality project, provides a comprehensive overview of the current research on integrating UMH into immersive VR, serving as a resource for researchers and designers in the field.}
}

@article{johanssonCodingUseTactile2009,
  title = {Coding and Use of Tactile Signals from the Fingertips in Object Manipulation Tasks},
  author = {Johansson, Roland S. and Flanagan, J. Randall},
  date = {2009-05},
  journaltitle = {Nature Reviews Neuroscience},
  shortjournal = {Nat. Rev. Neurosci.},
  doi = {10.1038/nrn2621},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: This review addresses emerging concepts regarding the use of tactile information by the brain in manipulation tasks, positing that planning and control center on mechanical events marking transitions between action phases and representing task subgoals while highlighting findings that explain the speed of tactile event detection and discussing multisensory representation to differ from prior reviews by emphasizing control, other sensory contributions, and central neural mechanisms. When humans manipulate objects the brain utilizes tactile afferent information regarding contact forces surface shapes and friction relying on four functionally distinct afferent types in the hand where FA-I and SA-I terminate superficially with high fingertip density for dynamic and static deformation respectively while FA-II and SA-II terminate deeper in fibrous tissues for transient events and shear strain. Traditional studies on gentle touch provide limited insight into manipulation because control processes are subconscious forces differ and receptive fields are larger than classical cutaneous delineations due to complex tissue mechanics rendering pixel-like sensor array models unviable. Dexterous manipulation tasks consist of action phases delimited by mechanical events serving as subgoals requiring action-phase controllers that predict sensory events to link phases smoothly given sensorimotor delays utilizing finite-state control logic where errors detected via predicted versus actual signal comparisons trigger context-dependent corrective actions and memory updates. Grasp contact ensures stability with initial responses in FA-I and SA-I afferents conveying contact timing site and force direction which are crucial for monitoring reach accuracy and are processed in areas like the primary sensorimotor cortex and intraparietal area. Grasp stability involves adapting grip forces to load forces based on predictions of dynamical properties influenced by friction and shape where mismatches trigger corrective actions updating surface property representations supported by the posterior parietal cortex and cerebellum though basic coupling remains robust to lesions. Contacts between objects and other objects engage FA-II afferents to signal incidence and dynamics facilitating efficient lifting through accurate weight predictions derived from experience or cues with mismatches detected by the right inferior parietal cortex and corrected via cerebellum or sensorimotor cortex depending on the nature of the weight error. Rapid detection of prediction errors implies that relative spike timing in ensembles of tactile afferents conveys critical information about surface shape and force direction faster than rate coding suggesting coincidence detection in second-order neurons converts temporal patterns into spatial codes for classification. Multisensory representation involves gaze directing to key locations predicting contact events allowing integration of somatosensory auditory and visual information in parietal and frontal cortices to monitor performance and align modalities for learning. Finally the authors conclude that dexterous manipulation serves as a model for sensorimotor control centered on discrete events enabling error correction and learning noting that future research must elucidate how action-phase controllers are coordinated across neural networks and how descending pathways modulate ascending tactile processing during movement.}
}

@article{johanssonTactileSensoryCoding1983,
  title = {Tactile Sensory Coding in the Glabrous Skin of the Human Hand},
  author = {Johansson, Roland S. and Vallbo, \AA ke B.},
  date = {1983-01},
  journaltitle = {Trends in Neurosciences},
  shortjournal = {Trends Neurosci.},
  doi = {10.1016/0166-2236(83)90011-5},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: The research paper presented by Johansson and Vallbo provides a comprehensive review of tactile sensory coding within the glabrous skin of the human hand, establishing the critical partnership between the human hand and the brain in exploring and reshaping the physical world through accurate mechanical descriptions. Utilizing the microneurographic technique introduced by Vallbo and Hagbarth, which involves percutaneously inserted tungsten microelectrodes to record impulses from single nerve fibres in awake human subjects, the authors were able to analyze tactile neural mechanisms with a precision previously available only in anesthetized animal experiments while simultaneously exploring the subject's psychophysical experience. The study focuses on the approximately 17,000 mechanoreceptive units innervating the hairless volar skin, which are classified into two major categories based on their response to sustained step indentation: slowly adapting units, which constitute about 44\% and respond with a sustained discharge, and fast-adapting units, comprising 56\% and responding with a burst of impulses only at stimulus onset and removal. Within these categories, four distinct types are distinguished by receptive field properties: the fast-adapting type I (FA I) and slow-adapting type I (SA I) units possess small, well-defined fields with sharp borders, whereas the fast-adapting type II (FA II) and slow-adapting type II (SA II) units exhibit wider fields with obscure boundaries. Anatomically, the end-organs corresponding to these units are identified as Meissner corpuscles for FA I units located in the papillary ridges, Merkel cell-neurite complexes for SA I units at the tip of intermediate epidermal ridges, Ruffini endings for SA II units in the dermis, and Pacinian corpuscles for FA II units in deeper skin layers and subcutaneous tissues. The functional specialization of these units is evident in their respective roles, where FA I and SA I units facilitate the extraction of spatial details and edge contours due to their high density and small receptive fields, particularly at the finger tips where density reaches 140 units cm\textasciicircum -2 for FA I and 70 units cm\textasciicircum -2 for SA I, correlating strongly with spatial discriminative capacity and psychophysical two-point discrimination thresholds. In contrast, the FA II and SA II units, with their low and relatively uniform density and large receptive fields, are not primarily involved in detailed spatial discrimination but instead encode temporal features such as vibrations between 100 Hz and 300 Hz for FA II units and lateral skin stretch for SA II units, the latter providing crucial information for evaluating shearing forces and controlling grip forces during manual manipulation. Furthermore, the study highlights that cutaneous mechanoreceptors contribute to proprioception and kinesthesia, as evidenced by the responsiveness of SA II and FA II units to joint movements and changes in skin tension patterns independent of direct touch, suggesting a role in motor control beyond simple exteroception. The correlation between neuronal activity and psychophysical phenomena reveals that detection thresholds for fine touch are set by peripheral mechanisms, specifically the sensitivity of FA I units, which often match psychophysical thresholds perfectly in high-acuity regions like the fingertip, whereas magnitude scaling suggests that subjective intensity grows faster than single-unit activity, implying significant contributions from central processing and unit recruitment. Finally, microstimulation studies demonstrate that electrically stimulating a single afferent fibre elicits sensations matching its functional class, such as light pressure for SA I units or buzzing and fluttery sensations for FA I units, thereby bridging the gap between biophysical events in the nervous system and mental events in the mind, ultimately supporting the view that the peripheral organization of mechanoreceptive units imposes fundamental constraints on human tactile perception and motor integration.}
}

