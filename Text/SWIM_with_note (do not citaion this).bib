@article{johnsonRolesFunctionsCutaneous2001,
  title = {The Roles and Functions of Cutaneous Mechanoreceptors},
  author = {Johnson, K},
  date = {2001-08-01},
  journaltitle = {Current Opinion in Neurobiology},
  shortjournal = {Curr. Opin. Neurobiol.},
  doi = {10.1016/S0959-4388(00)00234-8},
  keywords = {/unread},
  note = {Paper Summary: Combined psychophysical and neurophysiological research has resulted in a relatively complete picture of the neural mechanisms of tactile perception, supporting the idea that each of the four mechanoreceptive afferent systems innervating the hand serves a distinctly different perceptual function and that tactile perception can be understood as the sum of these specialized functions. The four cutaneous mechanoreceptive afferent neuron types comprise slowly adapting type 1 (SA1) afferents ending in Merkel cells, rapidly adapting (RA) afferents ending in Meissner corpuscles, Pacinian (PC) afferents ending in PC corpuscles, and slowly adapting type 2 (SA2) afferents terminating in Ruffini corpuscles, where receptor selectivity is due as much to the surrounding structure as to the transducer itself. The Merkel cell--SA1 afferent system innervates the skin densely with about 100 per cm2 at the fingertip, responding to sustained indentation with a linear discharge rate that makes it selectively sensitive to strain energy density, edges, corners, and curvature, thereby enabling high spatial resolution of 0.5 mm and an acute neural image of surface form that underlies texture and form perception independent of contact force or scanning velocity up to 80 mm s--1. As illustrated by the response profiles to aperiodic gratings, SA1 afferents resolve spatial detail smaller than their receptive field diameters by emphasizing stimulus features like edges over indentation per se, and population recordings confirm they provide a veridical neural image of curved surfaces that accounts for human curvature discrimination thresholds. In contrast, Meissner--RA afferents are even more densely innervated at about 150 per cm2 but are insensitive to static deformation and respond uniformly across their 3--5 mm receptive fields, rendering them poorly suited for spatial acuity but highly effective at transmitting a robust neural image of skin motion responsible for detecting low frequency vibration and microscopic slips that trigger reflexive grip force adjustments. This RA system functions analogously to the scotopic visual system with greater sensitivity but poorer resolution, serving as the essential feedback sensor for grip control where rapid adjustments prevent overt slip during object manipulation. The Pacinian afferents terminate in single corpuscles distributed throughout the palm and fingers and exhibit three remarkable properties: extreme sensitivity to nanometer-range skin motion, intense filtering of low-frequency stimuli that protects the receptor from ordinary manual labor stresses, and phase-locked Poisson discharge patterns that allow the population to represent complex waveforms accurately. Because of these properties, the PC system provides a high-fidelity neural image of transient vibratory stimuli, facilitating the perception of distant events through objects held in the hand such as tools, with detection thresholds falling from 5.6 {$\mu$}m to 0.03 {$\mu$}m between 20 and 150 Hz consistent with a mechanism sensitive to the third temporal derivative of tissue displacement known as jerk. The SA2 afferents, which innervate the skin less densely and possess larger receptive fields, are significantly more sensitive to skin stretch than indentation, signaling a neural image of skin stretch that contributes to the perception of hand shape and finger position through conformational patterns and aids in discriminating the direction of object motion or force when it produces skin stretch, although their role remains less secure than the other three systems given they are rarely observed in monkey studies. The accumulated evidence suggests a sharp division of function where the SA1 system encodes spatial structure for form and texture, the RA system encodes motion for grip control, the PC system encodes transmitted vibrations for tool use, and the SA2 system encodes skin stretch for hand conformation and motion direction, implying the existence of distinct central processing pathways for each primary afferent group. A major challenge identified is mapping these central pathways since suprathreshold stimuli typically activate all four systems simultaneously, necessitating selective stimulation techniques to isolate the computational operations underlying the perceptual functions of form, texture, motion, vibration, and kinesthetic awareness within the somatosensory cortex.}
}

@article{kingAcousticRadiationPressure1934a,
  ids = {kingAcousticRadiationPressure1934},
  title = {On the Acoustic Radiation Pressure on Spheres},
  author = {King, Louis Vessot},
  date = {1934-11-15},
  journaltitle = {Proceedings of the Royal Society of London. Series a - Mathematical and Physical Sciences},
  shortjournal = {Proc. R. Soc. Lond., Ser. - Math. Phys. Sci.},
  doi = {10.1098/rspa.1934.0215},
  langid = {english},
  keywords = {/unread},
  note = {Paper Summary: Louis V. King's 1934 research paper, titled On the Acoustic Radiation Pressure on Spheres, systematically develops the theoretical framework for calculating actual pressures on obstacles of simple geometrical form, specifically spheres, addressing the gap in existing treatises where no systematic theoretical development enabled such calculations particularly in the audible and supersonic ranges where direct pressure amplitude measurement becomes intractable due to diffraction problems and stroboscopic difficulties. The author posits that at supersonic frequencies the acoustic radiation pressures on spheres become sufficiently large to be measured easily in liquids, assuming the mean pressure is proportional to the energy density in the neighbourhood of the obstacle, a basis that allows for relative measurements in the radiation field of a supersonic oscillator and offers an explanation for the formation of dust figures observed in resonance tubes filled with gas and the dust striations in supersonic radiation fields in water observed by Boyle and his co-workers. Although the initial analysis neglects the compressibility of the spheres and the viscosity of the medium, expecting the formulae for rigid spheres in a frictionless medium to give correct orders of magnitude suitable for designing spherical torsion balances, the author notes the procedure may be extended to obtain more refined formulae including these factors. The theoretical development begins in Section 2 with the derivation of the pressure in a compressible fluid, defining the density, pressure intensity, and velocity components, and rewriting the equations of motion in terms of a variable sigma defined by the integral of dp over rho, leading to a pressure variation equation correct to terms of the order q squared over c squared which incorporates the velocity potential phi and accounts for the motion of the origin when the obstacle performs small linear and angular oscillations under the influence of the first-order pressure. Section 3 establishes the boundary conditions for a rigid spherical obstacle of mass M and mean density rho1, providing the dynamical equation of motion involving the integration of the pressure variation over the sphere's surface and the continuity condition requiring the fluid to remain in contact with the sphere, thereby relating the radial derivative of the velocity potential to the sphere's velocity. Section 4 presents the solution of the wave equation referred to the centre of the sphere as origin, expressed as a series of surface-harmonics multiplied by spherical wave functions, utilizing well-known properties and recurrence relations of these functions to determine the coefficients that satisfy the boundary conditions and the dynamical equation, distinguishing between Lamb's notation and Bessel-function notation for clarity. Section 5 details the calculation of the acoustic radiation pressure on a sphere by decomposing the pressure variation into contributions from the velocity potential squared term, the kinetic energy term, and the motion of the origin, integrating these components over the sphere surface to derive a general series expression for the total mean pressure which combines the three contributions into a comprehensive formula dependent on the coefficients of the incident radiation field. Section 6 outlines the numerical computation of these coefficients, providing formulae for H squared involving Bateman's functions and polynomials in inverse powers of the dimensionless parameter alpha, noting that two terms of the series are accurate to better than one-tenth of a percent for alpha equal to one, while for larger values Bessel function tables are utilized. Applying these general results to a plane progressive wave in Section 7 reveals that the radiation pressure on a sphere is always positive in the direction of wave propagation, and for spheres whose circumference is very small compared to the wavelength, the pressure is related to the mean total energy-density by a relative density factor F which is always finite and positive with a minimum at a specific density ratio, though the magnitude is found to be too small to be observed in water except when the intensity exceeds a level of 100 decibels. In contrast, Section 8 analyzes the radiation pressure on a sphere in a plane stationary wave, finding that the pressure is periodic depending on the position of the centre of the sphere with respect to the planes of loops and nodes, and for small spheres the mean radiation pressure is of a much greater order of magnitude than that exerted by progressive waves with the same maximum amplitude, where the direction of force urges relatively dense spheres away from the nodes towards the loops and relatively light spheres away from the loops towards the nodes. Section 9 discusses the motion of small spheres in a plane stationary radiation field, adding the term for mean velocity to the velocity potential and deriving an equation of motion similar to that of a simple pendulum where the position of stable equilibrium depends on the sign of the relative density factor, allowing for the calculation of the time of oscillation which is independent of the radius of the sphere and explains the phenomenon of sharply defined dust striations observed in supersonic fields. Section 10 further examines the influence of radiation pressure on dust in resonance tubes, proposing that radiation pressure plays an important part in the formation of well-known striated patterns assumed by light particles when standing waves are excited, accounting for antinodal discs formed by circulation and nodal wall striations arising from secondary transverse waves set up in the tube walls. Section 11 provides a detailed mathematical investigation of the formation of dust striations in stationary waves considering the effect of viscosity and gravity on the trajectory of falling particles, showing that the density distribution at a depth z is determined by the amplitude, wavelength, and relative density but is independent of the particle radius, with numerical examples demonstrating that at high frequencies radiation pressure produces very sharp striations consistent with observations by Boyle and his collaborators. Section 12 explores the suspension of small spherical particles against gravity in a vertical column of fluid where supersonic stationary waves are generated, concluding that equilibrium is always possible at the loops for nearly buoyant spherules in water with attainable velocity amplitudes, whereas in air the required amplitudes are beyond experimental realization, suggesting that sensitive balances could supplement optical observations. Finally, Section 13 summarizes and concludes the investigation by reiterating the pressure variation formula for compressible media, the second-order time average of the acoustic radiation pressure on a sphere comprising three specific contributions, the general expression obtained for radially symmetrical radiation fields, the specific results for plane progressive and stationary waves highlighting the higher order magnitude in stationary fields, the pendulum-like motion of small spheres, the independence of striation formation time from particle radius, the trajectory equations for particles controlled by viscosity, and the potential utility of these results in designing torsion balances of optimum sensitivity for the measurement of amplitudes in stationary supersonic radiation fields.}
}

